# General project settings
PROJECT_NAME=sokatechnologies-starter-kit
APP_ENV=development
APP_PORT=3000
LOG_LEVEL=info

# Base URLs
APP_BASE_URL=http://localhost:3000
API_BASE_URL=https://api.example.invalid

# Data layer placeholders
DATABASE_URL=driver://user:password@localhost:5432/database_name
CACHE_URL=protocol://localhost:6379/0

# Authentication placeholders
AUTH_PROVIDER=to-be-defined
AUTH_SECRET=not-a-real-secret

# External integration placeholders
INTEGRATION_API_TOKEN=not-a-real-token
WEBHOOK_SHARED_SECRET=not-a-real-webhook-secret

# Observability placeholders
ERROR_REPORTING_DSN=https://public-key@example.invalid/project-id
